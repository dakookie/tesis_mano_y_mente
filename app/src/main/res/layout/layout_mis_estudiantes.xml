<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="24dp"
    android:paddingStart="24dp"
    android:paddingEnd="24dp">

    <!-- ENCABEZADOS DE LA TABLA (Fijos en la parte superior) -->
    <LinearLayout
        android:id="@+id/llCabeceraTabla"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nombre_tabla_estudiantes"
            android:textColor="#5D4037"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/avatar_tabla_estudiantes"
            android:textColor="#5D4037"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.9"
            android:gravity="center"
            android:text="@string/edad_tabla_estudiantes"
            android:textColor="#5D4037"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/editar_tabla_estudiantes"
            android:textColor="#5D4037"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/accion_tabla_estudiante"
            android:textColor="#5D4037"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- LÍNEA PRINCIPAL (Debajo de los encabezados) -->
    <View
        android:id="@+id/vLineaPrincipal"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="#A1887F"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llCabeceraTabla" />

    <!-- LISTA DE ESTUDIANTES (La tabla en sí, desplazable) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvListaEstudiantes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:scrollbarSize="6dp"
        android:scrollbarThumbVertical="@android:color/darker_gray"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/vLineaPrincipal"
        tools:listitem="@layout/item_estudiante"
        tools:itemCount="15" />

</androidx.constraintlayout.widget.ConstraintLayout>