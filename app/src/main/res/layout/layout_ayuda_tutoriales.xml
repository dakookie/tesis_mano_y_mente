<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="true"
    android:clipToPadding="true"
    android:fadeScrollbars="false"
    android:fillViewport="true"
    android:paddingStart="16dp"
    android:paddingTop="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp"
    android:scrollbarSize="4dp"
    android:scrollbarStyle="insideOverlay"
    android:scrollbarThumbVertical="@drawable/bg_scrollbar"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="true"
        android:clipToPadding="true"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <!-- TÍTULO PRINCIPAL -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Tutoriales en Video"
            android:textColor="#5D4037"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- ================================================= -->
        <!-- VIDEO 1: CONEXIÓN Y SINCRONIZACIÓN                 -->
        <!-- ================================================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Conexión y Sincronización"
            android:textColor="#5D4037"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:text="Aprende a encender la mesa y vincularla a la aplicación mediante Bluetooth."
            android:textColor="#8D6E63"
            android:textSize="15sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:clipChildren="true"
            android:clipToOutline="true"
            android:clipToPadding="true"
            app:cardBackgroundColor="#000000"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#000000"
                android:clipChildren="true"
                android:clipToPadding="true">

                <androidx.media3.ui.PlayerView
                    android:id="@+id/videoConexion"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="#000000"
                    android:keepScreenOn="true"
                    app:layout_constraintDimensionRatio="H,16:9"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:resize_mode="fit"
                    app:show_buffering="when_playing"
                    app:surface_type="texture_view"
                    app:use_controller="true" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ================================================= -->
        <!-- VIDEO 2: USO DEL LECTOR RFID                      -->
        <!-- ================================================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Interacción juego y mesa"
            android:textColor="#5D4037"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:text="Técnica correcta para colocar las figuras y lograr una lectura inmediata."
            android:textColor="#8D6E63"
            android:textSize="15sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:clipChildren="true"
            android:clipToOutline="true"
            android:clipToPadding="true"
            app:cardBackgroundColor="#000000"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#000000"
                android:clipChildren="true"
                android:clipToPadding="true">

                <androidx.media3.ui.PlayerView
                    android:id="@+id/videoRfid"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="#000000"
                    android:keepScreenOn="true"
                    app:layout_constraintDimensionRatio="H,16:9"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:resize_mode="fit"
                    app:show_buffering="when_playing"
                    app:surface_type="texture_view"
                    app:use_controller="true" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ================================================= -->
        <!-- VIDEO 3: GESTIÓN DEL AULA                         -->
        <!-- ================================================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. Gestión del Aula"
            android:textColor="#5D4037"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:text="Cómo registrar nuevos estudiantes e iniciar una sesión de juego guiada."
            android:textColor="#8D6E63"
            android:textSize="15sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:clipChildren="true"
            android:clipToOutline="true"
            android:clipToPadding="true"
            app:cardBackgroundColor="#000000"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#000000"
                android:clipChildren="true"
                android:clipToPadding="true">

                <androidx.media3.ui.PlayerView
                    android:id="@+id/videoGestion"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="#000000"
                    android:keepScreenOn="true"
                    app:layout_constraintDimensionRatio="H,16:9"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:resize_mode="fit"
                    app:show_buffering="when_playing"
                    app:surface_type="texture_view"
                    app:use_controller="true" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>