<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.juego.FelicidadesActivity">

    <ImageView
        android:id="@+id/ivFondoFelicidades"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        android:src="@drawable/background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/glTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.22" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/glBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.80" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/glVertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.38" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cvBackJuego"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        app:cardCornerRadius="28dp"
        app:cardBackgroundColor="#DEB887"
        app:cardElevation="6dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/ibBackJuego"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/boton_retroceso"
            android:src="@drawable/ic_baseline_arrow_back_24"
            android:scaleType="centerInside"
            android:padding="12dp"
            app:tint="#5D4037" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cvSonidoJuego"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        app:cardCornerRadius="28dp"
        app:cardBackgroundColor="#DEB887"
        app:cardElevation="6dp"
        app:layout_constraintStart_toEndOf="@+id/cvBackJuego"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/ibSonidoJuego"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/boton_sonido"
            android:src="@drawable/ic_baseline_volume_up_24"
            android:scaleType="centerInside"
            android:padding="12dp"
            app:tint="#5D4037" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/llPerfilJugador"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_input_text"
        android:elevation="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvNombreJugador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/nombre_jugador"
            android:textColor="#5D4037"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivAvatarJugador"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:importantForAccessibility="no"
            android:src="@drawable/monster_astronaut" />
    </LinearLayout>

    <ImageView
        android:id="@+id/ivTituloFelicidades"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="13dp"
        android:importantForAccessibility="no"
        android:src="@drawable/title_final"
        app:layout_constraintWidth_percent="0.45"
        app:layout_constraintDimensionRatio="H,4:1"
        app:layout_constraintBottom_toTopOf="@+id/glTop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivMonsterCelebrando"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:importantForAccessibility="no"
        android:src="@drawable/monster_principal"
        app:layout_constraintHeight_percent="0.70"
        app:layout_constraintDimensionRatio="1:1.2"
        app:layout_constraintBottom_toTopOf="@+id/glBottom"
        app:layout_constraintEnd_toStartOf="@+id/glVertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/glTop" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ivPanelMadera"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/animals"
        app:layout_constraintBottom_toTopOf="@+id/glBottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/glVertical"
        app:layout_constraintTop_toBottomOf="@+id/glTop">

        <GridLayout
            android:id="@+id/gridPiezas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="24dp"
            android:columnCount="3"
            android:rowCount="2">

            <ImageView android:id="@+id/ivPieza1" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:importantForAccessibility="no"
                android:scaleType="fitCenter" android:padding="8dp"/>
            <ImageView android:id="@+id/ivPieza2" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:importantForAccessibility="no"
                android:scaleType="fitCenter" android:padding="8dp"/>
            <ImageView android:id="@+id/ivPieza3" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:importantForAccessibility="no"
                android:scaleType="fitCenter" android:padding="8dp"/>

            <ImageView android:id="@+id/ivPieza4" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:importantForAccessibility="no"
                android:scaleType="fitCenter" android:padding="8dp"/>
            <ImageView android:id="@+id/ivPieza5" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:importantForAccessibility="no"
                android:scaleType="fitCenter" android:padding="8dp"/>
            <ImageView android:id="@+id/ivPieza6" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:importantForAccessibility="no"
                android:scaleType="fitCenter" android:padding="8dp"/>
        </GridLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageView
        android:id="@+id/ibInicioJuego"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="@string/boton_inicio_felicidades"
        android:src="@drawable/button_home"
        app:layout_constraintHeight_percent="0.35"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/ibJugarNuevo"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/glBottom" />

    <ImageView
        android:id="@+id/ibJugarNuevo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:layout_marginStart="16dp"
        android:contentDescription="@string/boton_jugar_de_nuevo"
        android:src="@drawable/button_again"
        app:layout_constraintHeight_percent="0.15"
        app:layout_constraintDimensionRatio="1:0."
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/ibInicioJuego"
        app:layout_constraintTop_toBottomOf="@+id/glBottom" />

</androidx.constraintlayout.widget.ConstraintLayout>